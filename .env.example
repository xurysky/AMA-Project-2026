# Azure Credentials
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=rg-ama-retail
AZURE_LOCATION=eastasia

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://ama-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Cosmos DB
AZURE_COSMOS_ENDPOINT=https://ama-cosmos.documents.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-key
AZURE_COSMOS_DB=ama-retail
AZURE_COSMOS_CONTAINER=customer360
AZURE_COSMOS_RUNS_CONTAINER=agentRuns
ENABLE_COSMOS_RUN_STORE=false

# Event Hub
EVENT_HUB_CONNECTION_STRING=your-event-hub-connection
EVENT_HUB_NAME=ama-events

# Azure ML
AZURE_ML_WORKSPACE=ama-ml
AZURE_ML_KEY=your-ml-key

# Redis
REDIS_HOST=ama-redis.redis.cache.windows.net
REDIS_PORT=6380
REDIS_PASSWORD=your-redis-key
REDIS_SSL=True

# App Settings
LOG_LEVEL=INFO
ENVIRONMENT=development
